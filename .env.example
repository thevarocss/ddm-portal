# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# SMS API
MOSMS_SP_ID=your_sp_id
MOSMS_PASSWORD=your_password
MOSMS_SERVICE_ID=your_service_id
MOSMS_TELCO_URL=https://api.example.com/endpoint

# IVR
DDM_SMS_SP_ID=your_sp_id
DDM_SMS_SP_SECRET=your_secret
DDM_TELCO_SERVICE_ID=your_service_id
DDM_PG_HOST=localhost
DDM_PG_PORT=5432
DDM_PG_DB=your_db
DDM_PG_USER=your_user
DDM_PG_PASSWORD=your_password

# JWT
JWT_SECRET=your_jwt_secret

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password

# Deployment
DEPLOY_HOST=your.server.com
DEPLOY_USER=your_deploy_user
SSH_KEY_PATH=/path/to/ssh/key
